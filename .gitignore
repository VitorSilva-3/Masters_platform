# ==============================================================================
# PYTHON STANDARD
# ==============================================================================
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ==============================================================================
# VIRTUAL ENVIRONMENTS
# ==============================================================================
# Environments created locally should never be committed
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/

# ==============================================================================
# SECURITY & SECRETS (CRITICAL)
# ==============================================================================
# Never commit API keys, passwords or local environment variables
.env
.env.local
.env.*.local

# Streamlit secrets file (used for API keys in production)
.streamlit/secrets.toml

# ==============================================================================
# IDE & EDITOR SETTINGS
# ==============================================================================
# VS Code (User workspace settings)
.vscode/

# PyCharm / IntelliJ
.idea/

# Jupyter Notebooks (checkpoints)
.ipynb_checkpoints

# ==============================================================================
# OPERATING SYSTEM FILES
# ==============================================================================
# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# ==============================================================================
# LOGS & TEMPORARY FILES
# ==============================================================================
*.log
*.tmp
temp/
